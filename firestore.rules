rules_version = '2';
service cloud.firestore {
  match /databases/{database}/documents {
    // 0. Default deny
    match /{document=**} {
      allow read, write: if false;
    }

    // Helper functions
    function isSignedIn() {
      return request.auth != null;
    }

    function isEmailVerified() {
      return isSignedIn() && request.auth.token.email_verified == true;
    }

    function isSuperAdmin() {
      return isEmailVerified() && request.auth.token.email == 'izar.salas262@gmail.com';
    }

    function isValidId(id) {
      return id is string && id.size() <= 128 && id.matches('^[a-zA-Z0-9_\\-]+$');
    }

    function incoming() {
      return request.resource.data;
    }

    function existing() {
      return resource.data;
    }

    function isMemberOfBusiness(businessId) {
      return isSignedIn() && (businessId == request.auth.uid || exists(/databases/$(database)/documents/businesses/$(businessId)/members/$(request.auth.uid)));
    }

    function isOwnerOfBusiness(businessId) {
      return isSignedIn() && (businessId == request.auth.uid || get(/databases/$(database)/documents/businesses/$(businessId)).data.ownerId == request.auth.uid);
    }

    // Schema Validation Helpers
    function isValidProduct(data) {
      return data.keys().hasAll(['name', 'sellPrice']) &&
             data.name is string && data.name.size() > 0 && data.name.size() <= 200 &&
             data.sellPrice is number && data.sellPrice >= 0;
    }

    function isValidSale(data) {
      return data.keys().hasAll(['date', 'total', 'items']) &&
             data.total is number && data.total >= 0 &&
             data.items is list && data.items.size() > 0;
    }

    function isValidCustomer(data) {
      return data.keys().hasAll(['name']) &&
             data.name is string && data.name.size() > 0 && data.name.size() <= 200;
    }

    function isValidUser(data) {
        return data.keys().hasAll(['username', 'name', 'role']) &&
               data.username is string && data.name is string &&
               data.role in ['admin', 'cajero'];
    }

    function isValidCashOut(data) {
        return data.keys().hasAll(['amount', 'reason', 'date']) &&
               data.amount is number && data.reason is string && data.date is string;
    }

    // Businesses collection
    match /businesses/{businessId} {
      allow list: if isSuperAdmin();
      allow get: if isSignedIn();
      allow create: if isSignedIn() && incoming().ownerId == request.auth.uid;
      allow update: if (isOwnerOfBusiness(businessId) || isSuperAdmin()) && incoming().ownerId == existing().ownerId;
      
      // Products
      match /products/{productId} {
        allow read: if isMemberOfBusiness(businessId);
        allow create, update: if isMemberOfBusiness(businessId) && isValidProduct(incoming());
        allow delete: if isOwnerOfBusiness(businessId);
      }

      // Sales
      match /sales/{saleId} {
        allow list, get: if isMemberOfBusiness(businessId);
        allow create: if isMemberOfBusiness(businessId) && isValidSale(incoming());
        allow update, delete: if isOwnerOfBusiness(businessId);
      }

      // Customers
      match /customers/{customerId} {
        allow read: if isMemberOfBusiness(businessId);
        allow create, update: if isMemberOfBusiness(businessId) && isValidCustomer(incoming());
        allow delete: if isOwnerOfBusiness(businessId);
      }

      // Users
      match /users/{userId} {
        allow read: if isMemberOfBusiness(businessId);
        allow write: if isOwnerOfBusiness(businessId) && isValidUser(incoming());
      }

      // Cashouts
      match /cashouts/{cashoutId} {
        allow read: if isMemberOfBusiness(businessId);
        allow create: if isMemberOfBusiness(businessId) && isValidCashOut(incoming());
        allow update, delete: if isOwnerOfBusiness(businessId);
      }
    }
  }
}
